{{- $e := printf "%c" 27 -}}
{{- if not (hasKey . "headless") -}}
{{-   fail (printf "\n\n%s[38;5;204m  ✗ Missing config variable: headless%s[0m\n    Run: %s[38;5;78mchezmoi init%s[0m\n" $e $e $e $e) -}}
{{- end -}}
{{- if not (hasKey . "use_1password") -}}
{{-   fail (printf "\n\n%s[38;5;204m  ✗ Missing config variable: use_1password%s[0m\n    Run: %s[38;5;78mchezmoi init%s[0m\n" $e $e $e $e) -}}
{{- end -}}
# Brewfile — managed by chezmoi
# Install: brew bundle --file=~/.Brewfile
# Check:   brew bundle check --file=~/.Brewfile
#
# Layers: base (always) → dev (languages, infra) → apps (GUI casks)
# Control via chezmoi init prompts: headless, use_1password

# ══════════════════════════════════════════════════════════════════════
# BASE — essentials for every machine
# ══════════════════════════════════════════════════════════════════════

# ── Taps ──────────────────────────────────────────────────────────────
# homebrew/bundle and homebrew/services are now built-in (deprecated as taps)
tap "hashicorp/tap"

# ── Shell & Terminal ──────────────────────────────────────────────────
brew "fish"
brew "gum"                    # TUI components for shell scripts (Charm)
brew "starship"               # cross-shell prompt (git, languages, cmd duration)
brew "tmux"

# ── Core CLI (modern replacements) ───────────────────────────────────
brew "git"
brew "gh"                     # GitHub CLI (replaces hub)
brew "git-delta"              # better git diffs
brew "jq"
brew "yq"
brew "ripgrep"                # rg (replaces ag/grep)
brew "fd"                     # find replacement
brew "bat"                    # cat with syntax highlighting
brew "eza"                    # modern ls
brew "fzf"                    # fuzzy finder
brew "zoxide"                 # smart cd (replaces z)
brew "dust"                   # disk usage (du replacement)
brew "duf"                    # disk free (df replacement)
brew "procs"                  # ps replacement
brew "btop"                   # system monitor (replaces htop)
brew "choose-rust"            # cut/awk replacement
brew "direnv"
brew "tree"
brew "curl"
brew "wget"
brew "httpie"
brew "watch"
brew "tldr"
brew "shellcheck"             # shell script linter
brew "lnav"                   # log navigator
brew "chezmoi"                # dotfiles manager
brew "mdq"                    # jq for markdown
brew "tldr"                   # example-driven man pages
brew "sd"                     # simpler find/replace (sed alternative)
brew "gping"                  # ping with graph TUI
brew "atuin"                  # SQLite-backed shell history w/ sync

# ── Editors ───────────────────────────────────────────────────────────
brew "neovim"

# ── Security & Secrets ────────────────────────────────────────────────
brew "age"                    # file encryption (chezmoi encrypted_ files)
brew "certbot"                # Let's Encrypt / ACME client
brew "hashicorp/tap/vault"    # secrets management

{{ if not .headless -}}
# ══════════════════════════════════════════════════════════════════════
# DEV — languages, toolchains, infra (skip on headless/server)
# ══════════════════════════════════════════════════════════════════════

# ── Version Management ────────────────────────────────────────────────
brew "mise"                   # polyglot version manager (replaces nvm, rbenv, pyenv)

# ── Languages & Runtimes ─────────────────────────────────────────────
brew "go"
brew "golangci-lint"          # Go linter (replaces gometalinter)
brew "node"
brew "pnpm"
brew "uv"                     # fast Python package manager (replaces pipx)
brew "python@3.12"
brew "rustup"
brew "elixir"

# ── Git extras ────────────────────────────────────────────────────────
brew "git-filter-repo"
brew "git-sizer"
brew "lazygit"                # Git TUI
brew "difftastic"             # structural diff (syntax-aware)

# ── Containers & Infra ───────────────────────────────────────────────
cask "orbstack"               # container runtime (replaces Docker Desktop)
brew "colima"                 # lightweight container runtime (Lima VMs)
brew "docker"                 # Docker CLI
brew "docker-compose"         # multi-container orchestration
brew "docker-credential-helper"
brew "kubernetes-cli"
brew "k9s"                    # Kubernetes TUI
brew "kubectx"                # fast ctx/ns switching (includes kubens)
brew "kubecolor"              # colored kubectl output
brew "stern"                  # multi-pod log tailing
brew "helm"
brew "terraform"
brew "opentofu"               # community fork of terraform (CNCF)
brew "dive"                   # Docker image layer explorer (TUI)
brew "awscli"
brew "flyctl"
brew "caddy"
brew "nginx"
brew "cloudflared"

# ── Data & Media ──────────────────────────────────────────────────────
brew "duckdb"
brew "sqlite"
brew "ffmpeg"
brew "imagemagick"
brew "chafa"                  # terminal image renderer (kitty protocol)
brew "librsvg"                # SVG to PNG (rsvg-convert)
brew "optipng"
brew "qpdf"
brew "qrencode"
brew "graphviz"
brew "yt-dlp"                 # youtube-dl successor

# ── AI Tools ──────────────────────────────────────────────────────────
brew "aichat"                 # multi-LLM CLI
# llm via: uv tool install llm
# opencode via: npm i -g opencode-ai

# ── Build Tools ───────────────────────────────────────────────────────
brew "cmake"
brew "protobuf"
brew "buf"                    # modern Protobuf CLI (lint, breaking, compile)

# ── Web3 / DeFi ──────────────────────────────────────────────────────
# Foundry (cast for on-chain queries, anvil for local fork)
# Install: curl -L https://foundry.paradigm.xyz | bash && foundryup
brew "libusb"                 # hardware wallet (Ledger) support
# leo-lang via: cargo install leo-lang (Aleo ZK)

{{ if .use_1password -}}
# ── 1Password ─────────────────────────────────────────────────────────
cask "1password"
cask "1password-cli"
{{ end -}}

cask "nordvpn"                # VPN (cask, not formula)

# ══════════════════════════════════════════════════════════════════════
# APPS — GUI casks, fonts, Mac App Store
# ══════════════════════════════════════════════════════════════════════

# ── Terminal ──────────────────────────────────────────────────────────
cask "ghostty"
brew "mas"                    # Mac App Store CLI

# ── AI / LLM ─────────────────────────────────────────────────────────
cask "claude"                 # Claude desktop + Claude Code CLI
cask "codex"                  # OpenAI Codex CLI

# ── macOS Apps ────────────────────────────────────────────────────────
cask "visual-studio-code"
cask "zed"
cask "arc"
cask "google-chrome"
cask "microsoft-edge"
cask "discord"
cask "zoom"
cask "slack"
cask "raycast"
cask "devutils"
brew "gifski"                 # GIF encoder (moved from cask to formula)
cask "qbittorrent"
cask "gcloud-cli"             # GCP CLI tools (renamed from google-cloud-sdk)
cask "zen"                    # privacy-focused browser (renamed from zen-browser)

# ── Fonts ─────────────────────────────────────────────────────────────
cask "font-jetbrains-mono"
cask "font-jetbrains-mono-nerd-font"
cask "font-fira-code-nerd-font"
cask "font-source-code-pro"
cask "font-sauce-code-pro-nerd-font"
{{ end -}}

# ── Local overrides (machine-specific, not committed) ────────────────
# Add machine-specific packages to ~/.Brewfile.local
# This file is gitignored and not managed by chezmoi.
local_brewfile = File.expand_path("~/.Brewfile.local")
eval(File.read(local_brewfile), binding) if File.exist?(local_brewfile)

# ── npm Global Tools ─────────────────────────────────────────────────
# npm i -g ccusage markdownlint-cli2 npm-check-updates opencode-ai

# ── Cargo Tools ──────────────────────────────────────────────────────
# cargo install obsidian-export
