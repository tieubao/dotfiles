# Files to ignore based on OS/environment

# macOS-only (skip on Linux)
{{- if ne .chezmoi.os "darwin" }}
.config/ghostty/
.config/code/
.config/zed/
.Brewfile
.tool-versions
.docker/
{{- end }}

# Linux-only (skip on macOS)
{{- if ne .chezmoi.os "linux" }}
.config/systemd/
{{- end }}

# Never manage these
.DS_Store
.Trash
.cache
.Brewfile.local
.config/code/extensions.local.txt

# Codespaces / CI — skip GUI-dependent configs
{{- if env "CODESPACES" }}
.config/ghostty/
.config/code/
.config/zed/
.Brewfile
.claude/
{{- end }}

# Headless — skip Claude Code config
{{- if .headless }}
.claude/
{{- end }}
