#!/bin/bash
# Brewfile hash: {{ include "dot_Brewfile.tmpl" | sha256sum }}
# Re-runs only when Brewfile content changes.

_has_gum() { command -v gum &>/dev/null; }
_gum() { env -u UNDERLINE -u BOLD -u ITALIC -u FAINT -u STRIKETHROUGH gum "$@"; }
LOG="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles-apply.log"

_section() {
    if _has_gum; then
        _gum style --bold --foreground 75 "==> $*"
    else
        printf '\n\033[1;38;5;75m==> %s\033[0m\n' "$*"
    fi
}

_info() {
    if _has_gum; then
        _gum log --level info "$*"
    else
        printf '\033[38;5;78m  ✓\033[0m %s\n' "$*"
    fi
}

_warn() {
    if _has_gum; then
        _gum log --level warn "$1"
        [ -n "${2:-}" ] && _gum style --faint --foreground 245 --padding "0 0 0 8" "$2"
        [ -n "${3:-}" ] && _gum style --padding "0 0 0 8" \
            "$(_gum join "$(_gum style --faint --foreground 245 "Fix: ")" "$(_gum style --foreground 78 "$3")")"
    else
        printf '\033[38;5;192m  ⚠\033[0m \033[1m%s\033[0m\n' "$1"
        [ -n "${2:-}" ] && printf '\033[38;5;245m    %s\033[0m\n' "$2"
        [ -n "${3:-}" ] && printf '\033[38;5;245m    Fix: \033[38;5;78m%s\033[0m\n' "$3"
    fi
    echo "$(date +%Y-%m-%dT%H:%M:%S) WARN: $1${3:+ | Fix: $3}" >> "$LOG"
}

if ! command -v brew &>/dev/null; then
    echo "$(date +%Y-%m-%dT%H:%M:%S) FAIL: Homebrew not found | Fix: install Homebrew" >> "$LOG"
    # Don't exit 1 — let chezmoi continue to deploy files
    exit 0
fi

_section "Brewfile changed, running brew bundle..."
BREW_LOG=$(mktemp /tmp/dotfiles-brew-XXXXXXXX)

# Run brew bundle, capture exit code without pipefail killing us
rc=0
brew bundle --file="${HOME}/.Brewfile" --no-upgrade > "$BREW_LOG" 2>&1 || rc=$?
tail -5 "$BREW_LOG"

if [ "$rc" -ne 0 ]; then
    _warn "brew bundle had failures" \
         "Some packages could not be installed. Full log: $BREW_LOG" \
         "brew bundle --file=~/.Brewfile --verbose"
    # Exit 0 — brew failures shouldn't block config file deployment
else
    _info "brew bundle complete"
    rm -f "$BREW_LOG"
    echo "$(date +%Y-%m-%dT%H:%M:%S) OK: brew-bundle" >> "$LOG"
fi
