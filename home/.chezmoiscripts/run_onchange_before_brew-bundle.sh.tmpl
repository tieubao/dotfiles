#!/bin/bash
# Brewfile hash: {{ include "dot_Brewfile.tmpl" | sha256sum }}
# Re-runs only when Brewfile content changes.

if ! command -v brew &>/dev/null; then
    echo "==> Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

echo "==> Brewfile changed, running brew bundle..."
brew bundle --file="${HOME}/.Brewfile" --no-upgrade 2>&1 | tail -20
echo "==> brew bundle done"
