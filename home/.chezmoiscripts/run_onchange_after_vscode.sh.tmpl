#!/bin/bash
{{ if or (ne .chezmoi.os "darwin") (not (contains "code" .editor)) }}
exit 0
{{ end }}

set -eo pipefail

# VS Code settings hash: {{ include "dot_config/code/settings.json" | sha256sum }}
# VS Code extensions hash: {{ include "dot_config/code/extensions.txt" | sha256sum }}

LIB="$HOME/.config/dotfiles/lib.sh"
# shellcheck source=/dev/null
[ -f "$LIB" ] && source "$LIB" || { echo "dotfiles lib not found"; exit 1; }

VSCODE_USER="${HOME}/Library/Application Support/Code/User"

CODE_CMD=""
if command -v code &>/dev/null; then
    CODE_CMD="code"
elif [ -x "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" ]; then
    CODE_CMD="/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code"
fi

if [ -n "$CODE_CMD" ]; then
    section "Syncing VS Code settings"
    mkdir -p "$VSCODE_USER"
    cp "${HOME}/.config/code/settings.json" "$VSCODE_USER/settings.json"

    section "Checking VS Code extensions"
    installed=$("$CODE_CMD" --list-extensions 2>/dev/null | tr '[:upper:]' '[:lower:]')
    failed=0
    while IFS= read -r ext; do
        [ -z "$ext" ] && continue
        ext_lower=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
        if ! echo "$installed" | grep -qx "$ext_lower"; then
            if "$CODE_CMD" --install-extension "$ext" 2>/dev/null; then
                info "Installed: $ext"
            else
                warn "VS Code: failed to install $ext" \
                     "Extension may have been renamed or removed." \
                     "$CODE_CMD --install-extension $ext"
                failed=$((failed + 1))
            fi
        fi
    done < "${HOME}/.config/code/extensions.txt"

    # Also install local extensions (machine-specific, not committed to repo)
    LOCAL_EXT="${HOME}/.config/code/extensions.local.txt"
    if [ -f "$LOCAL_EXT" ]; then
        while IFS= read -r ext; do
            [ -z "$ext" ] && continue
            ext_lower=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
            if ! echo "$installed" | grep -qx "$ext_lower"; then
                if "$CODE_CMD" --install-extension "$ext" 2>/dev/null; then
                    info "Installed (local): $ext"
                else
                    warn "VS Code: failed to install local ext $ext"
                    failed=$((failed + 1))
                fi
            fi
        done < "$LOCAL_EXT"
    fi

    if [ "$failed" -gt 0 ]; then
        warn "VS Code: $failed extension(s) failed to install" \
             "Review warnings above for details." \
             "$CODE_CMD --install-extension <name> to retry individually"
    fi

    script_ok "vscode"
else
    warn "VS Code not found" \
         "Skipping settings sync and extension install." \
         "brew install --cask visual-studio-code"
fi
