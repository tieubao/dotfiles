#!/bin/bash
{{ if ne .chezmoi.os "darwin" }}
# Skip on non-macOS
exit 0
{{ end }}

set -eo pipefail

LIB="$HOME/.config/dotfiles/lib.sh"
# shellcheck source=/dev/null
[ -f "$LIB" ] && source "$LIB" || { echo "dotfiles lib not found"; exit 1; }

section "Applying macOS defaults"

safe_defaults() {
    if ! defaults write "$@" 2>/dev/null; then
        local domain="$1" key="$2"
        warn "defaults write $domain $key failed" \
             "May require a newer macOS version." \
             "defaults write $*"
    fi
}

# ── Dock ──────────────────────────────────────────────────────────────
safe_defaults com.apple.dock autohide -bool false
safe_defaults com.apple.dock tilesize -int 36
safe_defaults com.apple.dock orientation -string "left"
safe_defaults com.apple.dock show-recents -bool false
safe_defaults com.apple.dock minimize-to-application -bool true
safe_defaults com.apple.dock mru-spaces -bool false

# ── Finder ────────────────────────────────────────────────────────────
safe_defaults NSGlobalDomain AppleShowAllExtensions -bool true
safe_defaults com.apple.finder ShowPathbar -bool true
safe_defaults com.apple.finder ShowStatusBar -bool true
safe_defaults com.apple.finder AppleShowAllFiles -bool true
safe_defaults com.apple.finder FXPreferredViewStyle -string "Nlsv"
safe_defaults com.apple.finder _FXShowPosixPathInTitle -bool true
safe_defaults com.apple.finder FXEnableExtensionChangeWarning -bool false

# ── Keyboard ──────────────────────────────────────────────────────────
safe_defaults NSGlobalDomain KeyRepeat -int 2
safe_defaults NSGlobalDomain InitialKeyRepeat -int 15
safe_defaults NSGlobalDomain ApplePressAndHoldEnabled -bool false
safe_defaults NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
safe_defaults NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
safe_defaults NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
safe_defaults NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false

# ── Trackpad ──────────────────────────────────────────────────────────
safe_defaults com.apple.AppleMultitouchTrackpad Clicking -bool true
safe_defaults NSGlobalDomain com.apple.swipescrolldirection -bool true

# ── Screenshots ───────────────────────────────────────────────────────
mkdir -p "${HOME}/Screenshots"
safe_defaults com.apple.screencapture location -string "${HOME}/Screenshots"
safe_defaults com.apple.screencapture type -string "png"
safe_defaults com.apple.screencapture disable-shadow -bool true

# ── Mission Control ───────────────────────────────────────────────────
safe_defaults com.apple.spaces spans-displays -bool false

# ── Safari ────────────────────────────────────────────────────────────
safe_defaults com.apple.Safari ShowFullURLInSmartSearchField -bool true
safe_defaults com.apple.Safari IncludeDevelopMenu -bool true
safe_defaults com.apple.Safari AutoOpenSafeDownloads -bool false

# ── TextEdit ──────────────────────────────────────────────────────────
safe_defaults com.apple.TextEdit RichText -bool false

# ── Activity Monitor ──────────────────────────────────────────────────
safe_defaults com.apple.ActivityMonitor ShowCategory -int 0

# ── Apply ─────────────────────────────────────────────────────────────
for app in "Dock" "Finder" "SystemUIServer"; do
    killall "$app" &>/dev/null || true
done

script_ok "macos-defaults"
