#!/bin/bash
# Pre-check: validate 1Password CLI availability when use_1password=true.
{{ if not (hasKey . "use_1password") -}}
exit 0
{{ else if not .use_1password -}}
exit 0
{{ end -}}

set -eo pipefail

_has_gum() { command -v gum &>/dev/null; }
_gum() { env -u UNDERLINE -u BOLD -u ITALIC -u FAINT -u STRIKETHROUGH gum "$@"; }

_warn() {
    if _has_gum; then
        _gum log --level warn "$1"
        [ -n "${2:-}" ] && _gum style --faint --foreground 245 --padding "0 0 0 8" "$2"
        [ -n "${3:-}" ] && _gum style --padding "0 0 0 8" \
            "$(_gum join "$(_gum style --faint --foreground 245 "Fix: ")" "$(_gum style --foreground 78 "$3")")"
    else
        printf '\033[38;5;192m  ⚠\033[0m \033[1m%s\033[0m\n' "$1"
        [ -n "${2:-}" ] && printf '\033[38;5;245m    %s\033[0m\n' "$2"
        [ -n "${3:-}" ] && printf '\033[38;5;245m    Fix: \033[38;5;78m%s\033[0m\n' "$3"
    fi
    echo "$(date +%Y-%m-%dT%H:%M:%S) WARN: $1${3:+ | Fix: $3}" >> "${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles-apply.log"
}

if ! command -v op &>/dev/null; then
    _warn "1Password CLI (op) not found" \
          "Config has use_1password=true but op is not installed." \
          "brew install 1password-cli && eval \$(op signin)"
    exit 0
fi

if ! op account list &>/dev/null 2>&1; then
    _warn "1Password CLI not signed in" \
          "Secret injection via onepasswordRead will fail." \
          "eval \$(op signin)"
fi
