#!/bin/bash
{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

# Zed settings hash: {{ include "dot_config/zed/settings.json.tmpl" | sha256sum }}

ZED_USER="${HOME}/.config/zed"

if [ -d "/Applications/Zed.app" ] || command -v zed &>/dev/null; then
    echo "==> Zed settings applied via chezmoi (already at ~/.config/zed/settings.json)"
fi
