{{- $e := printf "%c" 27 -}}
{{- if not (hasKey . "use_1password") -}}
{{-   fail (printf "\n\n%s[38;5;204m  ✗ Missing config variable: use_1password%s[0m\n    Run: %s[38;5;78mchezmoi init%s[0m\n" $e $e $e $e) -}}
{{- end -}}
{{- if not (hasKey . "editor") -}}
{{-   fail (printf "\n\n%s[38;5;204m  ✗ Missing config variable: editor%s[0m\n    Run: %s[38;5;78mchezmoi init%s[0m\n" $e $e $e $e) -}}
{{- end -}}
// Zed settings — managed by chezmoi
// Edit: chezmoi edit ~/.config/zed/settings.json
{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "new_window",
{{- if .use_1password }}
  "context_servers": {
    // MCP server API keys injected from 1Password at `chezmoi apply` time.
    // Add your own MCP servers here with onepasswordRead references.
    // Example:
    // "mcp-server-github": {
    //   "source": "extension",
    //   "enabled": true,
    //   "settings": {
    //     "github_personal_access_token": "{{ "{{ onepasswordRead \"op://Vault/GitHub PAT/credential\" }}" }}"
    //   }
    // }
  },
{{- end }}
  "icon_theme": "Catppuccin Frappé",
  "agent": {
    "enable_feedback": false,
    "sidebar_side": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-latest"
    }
  },
  "theme": "One Dark",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "format_on_save": "off",
  "editor.wordWrap": "on",
  "terminal": {
    "scrollbar": {
      "show": "never"
    },
    "font_size": 12,
    "line_height": "standard",
    "dock": "right",
    "env": {
      "EDITOR": "{{ .editor }}"
    }
  }
}
