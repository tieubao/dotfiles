# secrets.fish — Secret loading for fish shell.
# Edit: chezmoi edit ~/.config/fish/conf.d/secrets.fish
# Apply: chezmoi apply
#
# Load secrets on demand via fish functions:
#   op-env GITHUB_TOKEN "op://Vault/GitHub Token/password"
#   keychain-env MY_TOKEN [service-name]
#   web3-env [vault-name]
#
# For apply-time injection, uncomment and edit lines below.

if status is-interactive
{{ if .use_1password }}
    # ── 1Password (resolved at `chezmoi apply` time) ─────────────────
    # Store first: op item create --vault="{{ .op_vault }}" --category=api_credential --title="OpenAI" password=sk-...
    # Then uncomment:
    # set -gx OPENAI_API_KEY "{{ onepasswordRead (printf "op://%s/OpenAI/credential" .op_vault) }}"
    # set -gx ANTHROPIC_API_KEY "{{ onepasswordRead (printf "op://%s/Anthropic/credential" .op_vault) }}"
    # set -gx GITHUB_TOKEN "{{ onepasswordRead (printf "op://%s/GitHub Token/credential" .op_vault) }}"
{{ else }}
    # 1Password not configured. Enable: chezmoi init (answer "yes" to 1Password)
{{ end }}
    # ── macOS Keychain ────────────────────────────────────────────────
    # Store: security add-generic-password -a "$USER" -s "MY_TOKEN" -w "secret123" -U
    # Load:  keychain-env MY_TOKEN
end
