# opencode via: npm i -g opencode-ai

# ── Security & Secrets ────────────────────────────────────────────────
cask "1password"
cask "1password-cli"
brew "nordvpn"

# ── Build Tools ───────────────────────────────────────────────────────
brew "cmake"
brew "protobuf"

