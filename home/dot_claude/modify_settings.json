#!/usr/bin/env bash
# Personal overlay for ~/.claude/settings.json.
#
# chezmoi invokes this script as a `modify_` source: current target on
# stdin, new target on stdout. Runs every `chezmoi apply`.
#
# Scope: guarantees personal fields are present (statusLine, the learning-
# capture Stop hook, four personal PreToolUse safety hooks, enabled plugins,
# skipDangerousModePermissionPrompt, permissions.defaultMode).
#
# Deliberately DOES NOT touch $schema, permissions.deny, or
# hooks.UserPromptSubmit -- those are owned by claude-guardrails and
# installed by the sibling run_onchange_after_claude-guardrails.sh script.
# permissions.defaultMode is ours; permissions.deny is theirs. We use an
# additive merge on the permissions object so both survive.
# For hooks.PreToolUse we use an additive merge: each managed entry is
# de-duplicated by marker string and appended to whatever guardrails
# (or the user) already put there, so guardrails' scan-commit.sh entry
# survives untouched.
#
# Managed PreToolUse hooks (each keyed by unique marker in its command):
#   "solo-worker mode"                           -- soft-warn git push to protected
#   "BLOCKED: Pipe-to-shell detected"            -- block curl|wget | bash/sh/zsh
#   "BLOCKED: Destructive delete"                -- block rm -rf /|~|$HOME
#
# Note: `git push` to main/master/production is intentionally only a warning,
# not a block. Solo workflow -- PR gating is not needed here.
# The dedup list still strips any previously installed block hook on apply.
#
# Idempotent: running multiple times yields the same result. Each managed
# hook is de-duplicated by its marker string so user-added siblings survive
# and our entries stay single.
set -euo pipefail

INPUT="$(cat)"
# Fail-open to empty object so a corrupt/new settings.json still gets
# our personal fields instead of a jq error + empty output.
if ! echo "$INPUT" | jq -e . >/dev/null 2>&1; then
    INPUT='{}'
fi

LEARNING_HOOK_CMD='echo '"'"'{"decision":"approve","reason":"LEARNING CAPTURE CHECK: Did you just explain a root cause, make a non-obvious architectural decision, identify a pattern, or break a debugging spiral? If yes, suggest capturing it. If no, carry on."}'"'"''

# Soft-warn on `git push` to protected branches (non-blocking, systemMessage).
# Solo-worker workflow: visible reminder, no hard block. Marker: "solo-worker mode".
GIT_PUSH_WARN_CMD='bash -c '"'"'CMD=$(cat | jq -r ".tool_input.command // empty"); if echo "$CMD" | grep -qEi "git[[:space:]]+push[[:space:]].*\b(main|master|production)\b"; then echo "{\"systemMessage\":\"Warning: direct push to protected branch. Continuing (solo-worker mode).\"}"; fi'"'"''

# Block curl|wget piped into a shell. Marker: "BLOCKED: Pipe-to-shell detected".
PIPE_SHELL_BLOCK_CMD='bash -c '"'"'CMD=$(cat | jq -r ".tool_input.command // empty"); if echo "$CMD" | grep -qEi "curl\s.*\|\s*(bash|sh|zsh)|wget\s.*\|\s*(bash|sh|zsh)"; then echo "BLOCKED: Pipe-to-shell detected. Download first, inspect, then execute." >&2; exit 2; fi'"'"''

# Block `rm -rf` against /, ~, or $HOME. Marker: "BLOCKED: Destructive delete".
RM_RF_BLOCK_CMD='bash -c '"'"'CMD=$(cat | jq -r ".tool_input.command // empty"); if echo "$CMD" | grep -qEi "rm\s+-(r|f|rf|fr)\s+(/|~|\$HOME)"; then echo "BLOCKED: Destructive delete. Use trash or move to tmp instead." >&2; exit 2; fi'"'"''

echo "$INPUT" | jq \
    --arg learning_cmd "$LEARNING_HOOK_CMD" \
    --arg git_push_warn_cmd "$GIT_PUSH_WARN_CMD" \
    --arg pipe_shell_block_cmd "$PIPE_SHELL_BLOCK_CMD" \
    --arg rm_rf_block_cmd "$RM_RF_BLOCK_CMD" '
    . as $existing |
    $existing + {
        enableAllProjectMcpServers: ($existing.enableAllProjectMcpServers // false),
        skipDangerousModePermissionPrompt: ($existing.skipDangerousModePermissionPrompt // true),
        permissions: (($existing.permissions // {}) + {
            defaultMode: (($existing.permissions // {}).defaultMode // "bypassPermissions")
        }),
        statusLine: ($existing.statusLine // {
            type: "command",
            command: "bash ~/.claude/statusline-command.sh"
        }),
        enabledPlugins: (($existing.enabledPlugins // {}) + {
            "ouroboros@ouroboros": true,
            "telegram@claude-plugins-official": true
        }),
        extraKnownMarketplaces: (($existing.extraKnownMarketplaces // {}) + {
            "ouroboros": {source: {source: "github", repo: "Q00/ouroboros"}},
            "claude-plugins-official": {source: {source: "github", repo: "anthropics/claude-plugins-official"}}
        })
    }
    | .hooks = ((.hooks // {}) + {
        Stop: (
            ((.hooks.Stop // []) | map(select(
                (.hooks // []) | map(.command // "" | contains("LEARNING CAPTURE CHECK")) | any | not
            ))) + [{hooks: [{type: "command", command: $learning_cmd, timeout: 5}]}]
        ),
        PreToolUse: (
            ((.hooks.PreToolUse // []) | map(select(
                (.hooks // []) | map(.command // "" as $c |
                    ($c | contains("BLOCKED: Direct push to protected branch")) or
                    ($c | contains("solo-worker mode")) or
                    ($c | contains("BLOCKED: Pipe-to-shell detected")) or
                    ($c | contains("BLOCKED: Destructive delete"))
                ) | any | not
            ))) + [
                {matcher: "Bash", hooks: [{type: "command", command: $pipe_shell_block_cmd}]},
                {matcher: "Bash", hooks: [{type: "command", command: $git_push_warn_cmd}]},
                {matcher: "Bash", hooks: [{type: "command", command: $rm_rf_block_cmd}]}
            ]
        )
    })
'
