#!/bin/bash
# secret-cache-read VAR_NAME OP_REF
#
# Returns a secret value, preferring macOS Keychain (silent) over 1Password (popup).
# Used by ~/.config/fish/conf.d/secrets.fish to lazy-load secrets at shell startup.
#
# Flow:
#   1. Check Keychain for VAR_NAME              → hit returns immediately (silent)
#   2. Keychain miss → op read OP_REF           → triggers 1Password popup (first time)
#   3. Cache result in Keychain for next time
#   4. Echo value (empty if all failed)
#
# Invalidate a cached secret with: dotfiles secret refresh VAR_NAME
set -eo pipefail

VAR="${1:?usage: secret-cache-read VAR_NAME OP_REF}"
REF="${2:?usage: secret-cache-read VAR_NAME OP_REF}"

# 1. Keychain first (silent after initial approval)
if VAL=$(security find-generic-password -a "$USER" -s "$VAR" -w 2>/dev/null); then
    [ -n "$VAL" ] && { printf '%s' "$VAL"; exit 0; }
fi

# 2. Fall back to 1Password (requires op CLI signed in — triggers popup)
if ! command -v op >/dev/null 2>&1; then
    # op not installed; fail silently so shell startup doesn't break
    exit 0
fi

if ! VAL=$(op read "$REF" 2>/dev/null); then
    # op read failed (not signed in, wrong ref, network issue, etc.)
    # Fail silently; $VAR will be empty, user can run `dotfiles secret refresh VAR`
    exit 0
fi

[ -z "$VAL" ] && exit 0

# 3. Cache in Keychain for next time (silent — user already approved op call)
security add-generic-password -a "$USER" -s "$VAR" -w "$VAL" -U 2>/dev/null || true

# 4. Return the value
printf '%s' "$VAL"
