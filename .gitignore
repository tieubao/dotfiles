# Secrets — never commit
*.secret
*.env
.env*

# OS
.DS_Store

# Fish runtime
fish_variables

# chezmoi state (local only)
home/.chezmoistate.boltdb

# age encryption key (machine-specific, backup in 1Password)
key.txt

# Claude — ignore local state, track shared config
.claude/*
!.claude/settings.json
!.claude/agents
!.claude/agents/*
!.claude/commands
!.claude/commands/*

# Machine-specific overrides, never committed to the shared repo.
# Defense-in-depth: .chezmoiignore blocks `chezmoi add` from tracking these,
# and these patterns block `git add` from catching anything that sneaks in.
# SSH host fragments containing internal hostnames, public IPs, or anything
# that fingerprints infrastructure live as `~/.ssh/config.d/*.local` on each
# machine and are restored on fresh-machine bootstrap from 1Password Secure
# Notes. See docs/guide.md > "Restore private SSH host fragments".
*.local
*.local.*
